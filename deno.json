{
  "name": "@hzrd149/nsite-gateway",
  "version": "3.1.0",
  "exports": "./main.ts",
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "@hono/hono/jsx",
    "lib": ["dom", "dom.iterable", "esnext", "deno.ns", "deno.unstable"]
  },
  "tasks": {
    "dev": "deno run --unstable-kv --env-file=.env --watch --allow-env --allow-net --allow-read --allow-write main.ts",
    "start": "deno run --unstable-kv --env-file=.env --allow-env --allow-net --allow-read --allow-write main.ts",
    "check": "deno check main.ts",
    "fmt": "deno fmt"
  },
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4.12.9",
    "@std/media-types": "jsr:@std/media-types@^1.1.0",
    "@std/path": "jsr:@std/path@^1.1.4",
    "applesauce-common": "npm:applesauce-common@next",
    "applesauce-core": "npm:applesauce-core@next",
    "applesauce-loaders": "npm:applesauce-loaders@next",
    "applesauce-relay": "npm:applesauce-relay@next",
    "debug": "npm:debug@^4.4.3",
    "rxjs": "npm:rxjs@^7.8.2",
    "xbytes": "npm:xbytes@^1.9.1"
  }
}
