# optional directory for per-cache Deno KV stores
# CACHE_PATH="./data/cache"

# How long to keep cached data (in seconds)
CACHE_TIME=3600

# How long to trust the cached preferred server for a blob (in seconds)
BLOB_SERVER_TTL=604800

# How long to avoid a server after it serves the wrong blob for a sha256 (in seconds)
BLOB_BAD_SOURCE_TTL=86400

# Max number of blob verification workers created on demand
VERIFY_WORKER_POOL_MAX=4

# A list of relays to find users relay lists (10002) and blossom servers (10063)
LOOKUP_RELAYS=wss://user.kindpag.es,wss://purplepag.es

# Extra nostr relays to use for loading site manifests
NOSTR_RELAYS=wss://relay.damus.io,wss://relay.primal.net

# A list of relays that should be used to cache nostr events
# CACHE_RELAYS=ws://localhost:4869

# A list of fallback blossom servers
BLOSSOM_SERVERS="https://nostr.download,https://cdn.satellite.earth"

# A blossom proxy server to check first for blobs (optional)
# When set, the gateway will check this proxy first before other servers.
# The proxy will receive BUD-10 discovery hints (xs=server hints, as=author pubkey) as query parameters.
# BLOSSOM_PROXY="https://blossom-proxy.example.com"

# The max file size to serve
MAX_FILE_SIZE="2 MB"

# The public domain of the gateway (optional) (used to detect when to show the nsite homepage)
PUBLIC_DOMAIN="nsite.gateway.com"

# If this is set, nsite will return the 'Onion-Location' header in responses
# ONION_HOST=https://<hostname>.onion
